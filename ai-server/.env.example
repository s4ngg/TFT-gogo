# Database
# Docker Compose sets DATABASE_URL from AI_SERVER_DATABASE_URL in the shell/root .env.
# This file is still loaded through env_file, but docker-compose.yml's environment
# value wins over ai-server/.env. For compose overrides, set AI_SERVER_DATABASE_URL.
# This DATABASE_URL is used when running ai-server directly on the host.
DATABASE_URL=postgresql+asyncpg://tftuser:tftpass@localhost:5432/tftgogo_ai
# AI_SERVER_DATABASE_URL=postgresql+asyncpg://tftuser:tftpass@postgres:5432/tftgogo_ai

# OpenAI
# 운영 환경에서 필수 (임베딩 API도 동일 키 사용)
OPENAI_API_KEY=your-openai-api-key
# 메타덱 추천 벡터 검색용 임베딩 모델 (기본값 사용해도 무방)
# 캐시가 (signature, model)로 분리돼 있어 바꿔도 안전하다 — 이전 모델의
# 캐시 행과 뒤섞이지 않고, 바꾼 시점부터는 새 모델로 다시 임베딩된다.
# 다만 이전 모델 캐시 행은 자동 삭제되지 않으니(더는 조회 안 될 뿐) 자주
# 바꾸는 경우 별도 정리가 필요할 수 있다.
# EMBEDDING_MODEL=text-embedding-3-small
# 차원(EMBEDDING_DIMENSIONS)은 여기서 못 바꾼다 — meta_deck_embedding 테이블
# 컬럼에 고정된 스키마 상수라 app/db/models.py + 새 alembic 마이그레이션이 필요하다.

# Riot API
RIOT_API_KEY=your-riot-api-key

# App
APP_ENV=development
APP_PORT=8000
SECRET_KEY=your-secret-key
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
# Required: set a unique secret per environment.
INTERNAL_SECRET=
