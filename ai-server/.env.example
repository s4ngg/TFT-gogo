# Database (docker-compose의 postgres 서비스: pgvector/pgvector image, DB명 tftgogo_ai)
# 주의: docker compose로 실행할 때는 이 값이 적용되지 않는다 — docker-compose.yml의
# environment.DATABASE_URL이 env_file보다 항상 우선하기 때문. docker compose 실행에서
# 접속 정보를 바꾸려면 이 파일이 아니라 AI_SERVER_DATABASE_URL을 셸/루트 .env에서 지정한다.
# 아래 값은 ai-server를 컨테이너 밖에서 직접 띄우거나(uvicorn/alembic 로컬 실행) 할 때만 쓰인다.
DATABASE_URL=postgresql+asyncpg://tftuser:tftpass@localhost:5432/tftgogo_ai

# OpenAI
# 운영 환경에서 필수 (임베딩 API도 동일 키 사용)
OPENAI_API_KEY=your-openai-api-key
# 메타덱 추천 벡터 검색용 임베딩 모델 (기본값 사용해도 무방)
# EMBEDDING_MODEL=text-embedding-3-small
# 차원(EMBEDDING_DIMENSIONS)은 여기서 못 바꾼다 — meta_deck_embedding 테이블
# 컬럼에 고정된 스키마 상수라 app/db/models.py + 새 alembic 마이그레이션이 필요하다.

# Riot API
RIOT_API_KEY=your-riot-api-key

# App
APP_ENV=development
APP_PORT=8000
SECRET_KEY=your-secret-key
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
# Required: set a unique secret per environment.
INTERNAL_SECRET=
