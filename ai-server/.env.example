# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/tftgogo

# OpenAI
# 운영 환경에서 필수
OPENAI_API_KEY=your-openai-api-key

# Riot API
RIOT_API_KEY=your-riot-api-key

# App
APP_ENV=development
APP_PORT=8000
SECRET_KEY=your-secret-key
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
# Required: set a unique secret per environment.
INTERNAL_SECRET=
