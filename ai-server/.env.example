# Database
# Docker Compose uses the postgres service hostname.
DATABASE_URL=postgresql+asyncpg://tftuser:tftpass@postgres:5432/tftgogo_ai
# If you run ai-server directly on the host while Postgres is exposed locally, use:
# DATABASE_URL=postgresql+asyncpg://tftuser:tftpass@localhost:5432/tftgogo_ai

# OpenAI
# 운영 환경에서 필수
OPENAI_API_KEY=your-openai-api-key

# Riot API
RIOT_API_KEY=your-riot-api-key

# App
APP_ENV=development
APP_PORT=8000
SECRET_KEY=your-secret-key
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
# Required: set a unique secret per environment.
INTERNAL_SECRET=
