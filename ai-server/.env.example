# Database (docker-compose의 postgres 서비스: pgvector/pgvector image, DB명 tftgogo_ai)
DATABASE_URL=postgresql+asyncpg://tftuser:tftpass@localhost:5432/tftgogo_ai

# OpenAI
# 운영 환경에서 필수 (임베딩 API도 동일 키 사용)
OPENAI_API_KEY=your-openai-api-key
# 메타덱 추천 벡터 검색용 임베딩 설정 (기본값 사용해도 무방)
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=256

# Riot API
RIOT_API_KEY=your-riot-api-key

# App
APP_ENV=development
APP_PORT=8000
SECRET_KEY=your-secret-key
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173
# Required: set a unique secret per environment.
INTERNAL_SECRET=
