<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%thread] %highlight{%-5level}{FATAL=red blink, ERROR=red bold, WARN=yellow bold, INFO=green, DEBUG=cyan, TRACE=white} %logger{36} - %msg%n" disableAnsi="false"/>
        </Console>
        <!-- Bearer 토큰, 비밀번호, 시크릿 등 민감 정보를 마스킹하는 Rewrite Appender -->
        <Rewrite name="Rewrite">
            <AppenderRef ref="Console"/>
            <!-- Bearer 토큰 마스킹 (Authorization 헤더 등) -->
            <RegexReplacement regex="Bearer\s+[A-Za-z0-9\-._~+/]+=*" replacement="Bearer [MASKED]"/>
            <!-- 비밀번호·시크릿·API 키 마스킹 -->
            <RegexReplacement regex="(?i)(password|passwd|pwd|secret|apikey|api[_-]key)\s*[:=]\s*\S+" replacement="$1=[MASKED]"/>
        </Rewrite>
        <RollingFile name="File" fileName="${sys:user.home}/tftgogo-logs/app.log"
                     filePattern="${sys:user.home}/tftgogo-logs/app-%d{yyyy-MM-dd}.log.gz">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="7"/>
        </RollingFile>
        <Rewrite name="RewriteFile">
            <AppenderRef ref="File"/>
            <RegexReplacement regex="Bearer\s+[A-Za-z0-9\-._~+/]+=*" replacement="Bearer [MASKED]"/>
            <RegexReplacement regex="(?i)(password|passwd|pwd|secret|apikey|api[_-]key)\s*[:=]\s*\S+" replacement="$1=[MASKED]"/>
        </Rewrite>
    </Appenders>

    <Loggers>
        <Logger name="com.tftgogo" level="DEBUG" additivity="false">
            <AppenderRef ref="Rewrite"/>
            <AppenderRef ref="RewriteFile" level="WARN"/>
        </Logger>
        <Logger name="org.springframework.security" level="INFO" additivity="false">
            <AppenderRef ref="Rewrite"/>
        </Logger>
        <Logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
            <AppenderRef ref="Rewrite"/>
        </Logger>
        <Root level="INFO">
            <AppenderRef ref="Rewrite"/>
            <AppenderRef ref="RewriteFile" level="WARN"/>
        </Root>
    </Loggers>
</Configuration>