<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Properties>
        <Property name="maskedMessage">%replace{%replace{%msg}{Bearer\s+[A-Za-z0-9\-._~+/]+=*}{Bearer [MASKED]}}{(?i)(password|passwd|pwd|secret|apikey|api[_-]key)\s*[:=]\s*\S+}{$1=[MASKED]}</Property>
    </Properties>

    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout charset="UTF-8" pattern="%d{yyyy-MM-dd HH:mm:ss} [%thread] %highlight{%-5level}{FATAL=red blink, ERROR=red bold, WARN=yellow bold, INFO=green, DEBUG=cyan, TRACE=white} %logger{36} - ${maskedMessage}%n" disableAnsi="false"/>
        </Console>
        <RollingFile name="File" fileName="${sys:user.home}/tftgogo-logs/app.log"
                     filePattern="${sys:user.home}/tftgogo-logs/app-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout charset="UTF-8" pattern="%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - ${maskedMessage}%n"/>
            <Policies>
                <TimeBasedTriggeringPolicy/>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>
            <DefaultRolloverStrategy max="7"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Logger name="com.tftgogo" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File" level="WARN"/>
        </Logger>
        <Logger name="org.springframework.security" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <Logger name="org.hibernate.SQL" level="WARN" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File" level="WARN"/>
        </Root>
    </Loggers>
</Configuration>
