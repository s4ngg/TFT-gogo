spring:
  profiles:
    active: local   # local | docker | prod
  datasource:
    url: jdbc:mysql://localhost:3306/tftgogo?useSSL=false&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true
    username: root
    password: your-db-password
    driver-class-name: com.mysql.cj.jdbc.Driver
  flyway:
    enabled: true
    locations: classpath:db/migration
    validate-on-migrate: true
    # GuideFlywayConfiguration derives V22 placeholders from app.guide.cdragon minimum counts.
    # New DB: Flyway applies V1__init_schema.sql onwards automatically.
    # Existing DB: run `flyway baseline -baselineVersion=16` once
    #   (16 = last migration version consolidated into V1).
    baseline-on-migrate: false
  jpa:
    hibernate:
      ddl-auto: validate
    show-sql: false
    properties:
      hibernate:
        dialect: org.hibernate.dialect.MySQL8Dialect
        format_sql: true
        default_batch_fetch_size: 100
  data:
    redis:
      host: localhost
      port: 6379
  security:
    oauth2:
      client:
        registration:
          google:
            client-id: your-google-client-id
            client-secret: your-google-client-secret
            redirect-uri: "{baseUrl}/login/oauth2/code/{registrationId}"
            scope:
              - profile
              - email
          naver:
            client-id: your-naver-client-id
            client-secret: your-naver-client-secret
            authorization-grant-type: authorization_code
            redirect-uri: "{baseUrl}/login/oauth2/code/{registrationId}"
            scope:
              - name
              - email
              - profile_image
        provider:
          naver:
            authorization-uri: https://nid.naver.com/oauth2.0/authorize
            token-uri: https://nid.naver.com/oauth2.0/token
            user-info-uri: https://openapi.naver.com/v1/nid/me
            user-name-attribute: response

jwt:
  secret: your-jwt-secret-key-must-be-32-chars-or-more
  access-token-expiration-millis: 3600000

riot:
  api-key: RGAPI-your-riot-api-key
  kr-base-url: https://kr.api.riotgames.com
  asia-base-url: https://asia.api.riotgames.com

ai:
  server:
    url: ${AI_SERVER_URL}   # Docker/ECS 운영: 내부 AI 서버 주소
    timeout-seconds: 10
    internal-secret: ${AI_SERVER_INTERNAL_SECRET}

admin:
  secret-token: your-admin-secret-token
  bootstrap:
    username: ${ADMIN_BOOTSTRAP_USERNAME:admin}
    password: ${ADMIN_BOOTSTRAP_PASSWORD:}

app:
  oauth2:
    authorization-base-uri: ${APP_OAUTH2_AUTHORIZATION_BASE_URI:https://tftgogo.com}
    authorized-redirect-uri: ${APP_OAUTH2_AUTHORIZED_REDIRECT_URI:https://tftgogo.com/oauth/callback}
    login-failure-redirect-uri: ${APP_OAUTH2_LOGIN_FAILURE_REDIRECT_URI:https://tftgogo.com/login}
  meta-deck:
    startup-aggregate: false
  guide:
    cdragon:
      # Keep this disabled in local/dev personal environments. Enable only on shared dev/prod servers.
      enabled: false
      startup-import: false
      # Use the latest current patch note version as the guide patch label.
      patch-version: latest
      # Required when the scheduler is enabled. This pair is the allowed source for patch-version.
      set-number: ${APP_GUIDE_CDRAGON_SET_NUMBER:}
      mutator: ${APP_GUIDE_CDRAGON_MUTATOR:}
      include-champions: true
      include-traits: true
      include-items: true
      include-augments: true
      # Reject requested guide types below these candidate counts before any data is stored.
      minimum-champion-count: ${APP_GUIDE_CDRAGON_MINIMUM_CHAMPION_COUNT:40}
      minimum-trait-count: ${APP_GUIDE_CDRAGON_MINIMUM_TRAIT_COUNT:20}
      minimum-item-count: ${APP_GUIDE_CDRAGON_MINIMUM_ITEM_COUNT:30}
      minimum-augment-count: ${APP_GUIDE_CDRAGON_MINIMUM_AUGMENT_COUNT:50}
      # Run after patch-note list checks so guide data follows newly imported patch notes.
      sync-cron: "0 10 * * * *"
      refresh-cron: "0 40 6 * * *"
      zone: Asia/Seoul
  patch-note:
    scheduler:
      # Keep this disabled in local/dev personal environments. Enable only on shared dev/prod servers.
      enabled: false
      startup-import: false
      locale: ko-kr
      current: true
      list-scan-limit: 5
      list-cron: "0 0 * * * *"
      refresh-cron: "0 30 6 * * *"
      zone: Asia/Seoul
  # CORS 허용 origin 목록 — allowCredentials=true이므로 wildcard(*) 사용 불가
  # 운영 환경변수 예: APP_CORS_ALLOWED_ORIGINS=https://tftgogo.com,https://www.tftgogo.com
  cors:
    allowed-origins:
      - http://localhost:3000       # 로컬 React (CRA)
      - http://localhost:5173       # 로컬 Vite dev server
      - http://127.0.0.1:5173
      - https://tftgogo.com
      - https://www.tftgogo.com

management:
  endpoints:
    web:
      exposure:
        include: health,metrics

server:
  port: 8080
  # ALB 뒤에서 원래 요청의 https host/protocol을 Spring이 인식하도록 설정
  forward-headers-strategy: framework

# ── 로컬 개발 시 SQL 로그 활성화 방법 ────────────────────────────
# Hibernate SQL DEBUG 로그는 기본(운영) 설정에서는 꺼져 있습니다.
# 로컬에서 SQL을 확인하려면 아래 설정을 추가하세요:
#
#   logging:
#     config: classpath:log4j2-local.xml
