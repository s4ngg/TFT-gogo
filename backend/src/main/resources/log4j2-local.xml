<?xml version="1.0" encoding="UTF-8"?>
<!-- 로컬 개발 전용 로그 설정 — SQL DEBUG 포함 -->
<!-- 활성화: application-local.yml에 logging.config: classpath:log4j2-local.xml 추가 -->
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout charset="UTF-8" pattern="%d{yyyy-MM-dd HH:mm:ss} [%thread] %highlight{%-5level}{FATAL=red blink, ERROR=red bold, WARN=yellow bold, INFO=green, DEBUG=cyan, TRACE=white} %logger{36} - %replace{%replace{%msg}{Bearer\s+[A-Za-z0-9\-._~+/]+=*}{Bearer [MASKED]}}{(?i)(password|passwd|pwd|secret|apikey|api[_-]key)\s*[:=]\s*\S+}{$1=[MASKED]}%n" disableAnsi="false"/>
        </Console>
        <RollingFile name="ErrorFile" fileName="logs/error.log"
                     filePattern="logs/error-%d{yyyy-MM-dd}.log">
            <PatternLayout charset="UTF-8" pattern="%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %replace{%replace{%msg}{Bearer\s+[A-Za-z0-9\-._~+/]+=*}{Bearer [MASKED]}}{(?i)(password|passwd|pwd|secret|apikey|api[_-]key)\s*[:=]\s*\S+}{$1=[MASKED]}%n%ex"/>
            <Policies>
                <TimeBasedTriggeringPolicy/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <Logger name="com.tftgogo" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ErrorFile" level="WARN"/>
        </Logger>
        <Logger name="org.springframework.security" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <!-- 로컬 개발: SQL 쿼리 DEBUG 출력 활성화 -->
        <Logger name="org.hibernate.SQL" level="DEBUG" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <Logger name="org.hibernate.orm.jdbc.bind" level="TRACE" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="ErrorFile" level="WARN"/>
        </Root>
    </Loggers>
</Configuration>
